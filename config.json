{
  "model_name": "gpt2-small",
  "dataloader": {
    "dataset_name": "bigcode/the-stack-smol",
    "split": "train",
    "data_dir": "data/python",
    "streaming": true,
    "text_field": "content"
  },
  "extraction": {
    "target": "blocks.0.hook_resid_post",
    "count": 1000,
    "chunk_size": 250000,
    "dtype": "bfloat16",
    "output_dir": ".",
    "output_prefix": "activations"
  },
  "datasets": {
    "path": [
      "activations_gpt2-small_blocks_0_hook_resid_post_0.pt",
      "activations_gpt2-small_blocks_0_hook_resid_post_1.pt",
      "activations_gpt2-small_blocks_0_hook_resid_post_2.pt"
    ]
  },
  "sae": {
    "hidden_dim": 12288,
    "sparsity_weight": 0.005,
    "sparsity_sweep": [0.001, 0.003, 0.005, 0.01, 0.02]
  },
  "train": {
    "batch_size": 256,
    "epochs": 8,
    "learning_rate": 0.0005,
    "weight_decay": 0.0,
    "device": "cuda",
    "validation_split": 0.1,
    "split_seed": 42,
    "feature_activity_threshold": 0.001,
    "output_model_path": "checkpoints/sae_k16.pt"
  }
}
