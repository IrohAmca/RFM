{
  "model_name": "gpt2-small",
  "dataloader": {
    "dataset_name": "dair-ai/emotion",
    "dataset_config_name": null,
    "split": "train",
    "data_dir": null,
    "streaming": false,
    "text_field": "text"
  },
  "extraction": {
    "target": "blocks.0.hook_resid_post",
    "count": 800,
