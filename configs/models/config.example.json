{
  "model_name": "gpt2-small",
  "contrast_axis": {
    "id": "contrast_axis",
    "endpoint_a": "baseline",
    "endpoint_b": "target",
    "display_name_a": "Baseline",
    "display_name_b": "Target",
    "orientation": "b_minus_a",
    "pair_key_fields": [
      "pair_id",
      "label",
      "question"
    ]
  },
  "dataloader": {
    "dataset_name": "bigcode/the-stack-smol",
    "split": "train",
    "data_dir": "data/python",
    "streaming": true,
    "text_field": "content"
  },
  "extraction": {
    "count": 100,
    "chunk_size": 1000000,
    "dtype": "bfloat16",
    "output_dir": ".",
    "output_prefix": "activations"
  },
  "layers": {
    "blocks.0.hook_resid_post": {
      "sae": {
        "hidden_dim": 3072,
        "sparsity_weight": 0.001
      },
      "train": {
        "batch_size": 1024,
        "epochs": 1,
        "learning_rate": 0.001,
        "weight_decay": 0.0,
        "device": "cpu",
        "save_path": "checkpoints/blocks_0_hook_resid_post/sae.pt"
      }
    },
    "blocks.6.hook_resid_post": {
      "sae": {
        "hidden_dim": 6144,
        "sparsity_weight": 0.001
      },
      "train": {
        "epochs": 3,
        "learning_rate": 0.0005,
        "save_path": "checkpoints/blocks_6_hook_resid_post/sae.pt"
      }
    }
  },
  "sae": {
    "hidden_dim": 3072,
    "sparsity_weight": 0.001
  },
  "train": {
    "batch_size": 1024,
    "epochs": 1,
    "learning_rate": 0.001,
    "weight_decay": 0.0,
    "device": "cpu",
    "save_path": "checkpoints/sae.pt"
  },
  "patterns": {
    "aggregation_candidates": [
      "mean",
      "topk_mean_4",
      "lastk_mean_8",
      "max"
    ],
    "cv_folds": 5,
    "feature_pool": {
      "endpoint_a": 12,
      "endpoint_b": 12,
      "interaction": 8
    },
    "stability_min_fraction": 0.6,
    "max_tree_depth": 5,
    "min_interaction_gain": 0.005,
    "intervention_min_shift": 0.01,
    "causal_intervention": {
      "local_files_only": true,
      "max_prompts": 2,
      "max_new_tokens": 48,
      "temperature": 0.0,
      "top_p": 1.0,
      "amplify_alpha": 5.0,
      "min_effect": 0.01
    }
  }
}
