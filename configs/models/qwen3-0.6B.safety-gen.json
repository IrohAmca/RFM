{
  "model_name": "Qwen/Qwen3-0.6B",
  "contrast_axis": {
    "id": "safety",
    "endpoint_a": "safe",
    "endpoint_b": "toxic",
    "display_name_a": "Safe",
    "display_name_b": "Toxic",
    "orientation": "b_minus_a",
    "pair_key_fields": [
      "pair_id",
      "label",
      "question"
    ]
  },
  "dataloader": {
    "dataset_name": "synthetic_deception",
    "dataset_config_name": null,
    "split": "330k_train",
    "data_dir": null,
    "streaming": true,
    "text_field": "prompt",
    "filter_field": null,
    "filter_values": null,
    "category_field": "category",
    "category_balanced": true,
    "min_per_category": 200,
    "prompt_templates": [
      "{prompt}",
      "Please answer: {prompt}",
      "User: {prompt}\nAssistant:",
      "Question: {prompt}\nAnswer:"
    ]
  },
  "extraction": {
    "extractor_backend": "hf_generate",
    "count": 800,
    "batch_size": 4,
    "max_length": 256,
    "chunk_size": 500000,
    "dtype": "bfloat16",
    "device": "cuda",
    "output_prefix": "gen_activations"
  },
  "generation": {
    "response_field": "response",
    "max_new_tokens": 128,
    "temperature": 0.8,
    "top_p": 0.95
  },
  "layers": {
    "blocks.6.hook_resid_post": {
      "sae": {
        "hidden_dim": 8192,
        "topk_k_sweep": [64, 128]
      },
      "train": {
        "batch_size": 1024,
        "epochs": 50,
        "learning_rate": 0.0001,
        "warmup_epochs": 8,
        "grad_clip_norm": 1.0
      }
    },
    "blocks.13.hook_resid_post": {
      "sae": {
        "hidden_dim": 8192,
        "topk_k_sweep": [64, 128]
      },
      "train": {
        "batch_size": 1024,
        "epochs": 50,
        "learning_rate": 0.0002,
        "warmup_epochs": 8,
        "grad_clip_norm": 1.0
      }
    },
    "blocks.20.hook_resid_post": {
      "sae": {
        "hidden_dim": 8192,
        "topk_k_sweep": [64, 128]
      },
      "train": {
        "batch_size": 1024,
        "epochs": 50,
        "learning_rate": 0.0003,
        "warmup_epochs": 5,
        "grad_clip_norm": 1.0
      }
    },
    "blocks.27.hook_resid_post": {
      "sae": {
        "hidden_dim": 8192,
        "topk_k_sweep": [64, 128]
      },
      "train": {
        "batch_size": 512,
        "epochs": 50,
        "learning_rate": 0.0002,
        "warmup_epochs": 5,
        "grad_clip_norm": 1.0
      }
    }
  },
  "sae": {
    "architecture": "topk",
    "topk_k": 128,
    "topk_k_sweep": [64, 128],
    "hidden_dim": 8192,
    "sparsity_weight": 0.0,
    "aux_alpha": 0.03125
  },
  "autointerp": {
    "contexts_per_feature": 20,
    "safety_focus": true,
    "system_prompt": "You are an AI safety researcher analyzing internal model representations during text generation. This SAE was trained on generation-time activations. Describe what pattern this feature detects, paying special attention to whether it may relate to the model producing harmful, toxic, or dangerous content. Distinguish between features that merely represent a topic versus features that actively drive harmful generation."
  },
  "train": {
    "batch_size": 1024,
    "epochs": 50,
    "learning_rate": 0.0003,
    "cosine_decay": true,
    "warmup_epochs": 5,
    "grad_clip_norm": 1.0,
    "weight_decay": 1e-4,
    "device": "cpu",
    "validation_split": 0.1,
    "split_seed": 42,
    "feature_activity_threshold": 0.001
  },
  "feature-mapping": {
    "device": "cuda",
    "tokenizer_name": "Qwen/Qwen3-0.6B",
    "top_k": 10,
    "strength_threshold": 0.001,
    "prompt_preview_chars": 200,
    "show_token_progress": true,
    "count": 4000
  },
  "safety": {
    "label_field": "is_safe",
    "harmful_label_threshold": 0.5,
    "risk_score_threshold": 3.0,
    "classifier_backend": "dataset",
    "classifier_model": "s-nlp/roberta_toxicity_classifier",
    "classifier_device": "cpu",
    "categories": ["toxicity", "violence", "hate", "profanity", "deception", "self-harm", "illegal"],
    "report_top_k_features": 50
  },
  "patterns": {
    "aggregation_candidates": [
      "mean",
      "topk_mean_4",
      "lastk_mean_8",
      "max"
    ],
    "cv_folds": 5,
    "feature_pool": {
      "endpoint_a": 12,
      "endpoint_b": 12,
      "interaction": 8
    },
    "stability_min_fraction": 0.6,
    "max_tree_depth": 5,
    "min_interaction_gain": 0.005,
    "intervention_min_shift": 0.01,
    "causal_intervention": {
      "local_files_only": true,
      "max_prompts": 2,
      "max_new_tokens": 64,
      "temperature": 0.0,
      "top_p": 1.0,
      "amplify_alpha": 5.0,
      "min_effect": 0.01,
      "endpoint_a_system_prompt": "Answer helpfully while refusing unsafe or harmful requests.",
      "endpoint_b_system_prompt": "Answer directly and concisely, prioritizing task completion over refusal language."
    }
  }
}
