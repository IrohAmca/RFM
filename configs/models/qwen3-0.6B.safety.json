{
  "model_name": "Qwen/Qwen3-0.6B",
  "contrast_axis": {
    "id": "safety",
    "endpoint_a": "safe",
    "endpoint_b": "toxic",
    "display_name_a": "Safe",
    "display_name_b": "Toxic",
    "orientation": "b_minus_a",
    "pair_key_fields": [
      "pair_id",
      "label",
      "question"
    ]
  },
  "dataloader": {
    "dataset_name": "synthetic_deception",
    "dataset_config_name": "annotated",
    "split": "train",
    "data_dir": null,
    "streaming": false,
    "text_field": "text",
    "filter_field": null,
    "filter_values": null
  },
  "extraction": {
    "extractor_backend": "hf",
    "count": 3000,
    "batch_size": 16,
    "max_length": 512,
    "chunk_size": 1000000,
    "dtype": "bfloat16",
    "device": "cuda"
  },
  "layers": {
    "blocks.6.hook_resid_post": {
      "sae": {
        "hidden_dim": 8192,
        "topk_k_sweep": [64, 128]
      },
      "train": {
        "batch_size": 4096,
        "epochs": 50,
        "learning_rate": 0.0001,
        "warmup_epochs": 8,
        "grad_clip_norm": 1.0
      }
    },
    "blocks.13.hook_resid_post": {
      "sae": {
        "hidden_dim": 16384,
        "topk_k_sweep": [128, 256]
      },
      "train": {
        "batch_size": 4096,
        "epochs": 50,
        "learning_rate": 0.0002,
        "warmup_epochs": 8,
        "grad_clip_norm": 1.0
      }
    },
    "blocks.20.hook_resid_post": {
      "sae": {
        "hidden_dim": 24576,
        "topk_k_sweep": [256, 384]
      },
      "train": {
        "batch_size": 4096,
        "epochs": 50,
        "learning_rate": 0.0003,
        "warmup_epochs": 5,
        "grad_clip_norm": 1.0
      }
    },
    "blocks.27.hook_resid_post": {
      "sae": {
        "hidden_dim": 32768,
        "topk_k_sweep": [512, 768]
      },
      "train": {
        "batch_size": 2048,
        "epochs": 50,
        "learning_rate": 0.0002,
        "warmup_epochs": 5,
        "grad_clip_norm": 1.0
      }
    }
  },
  "sae": {
    "architecture": "topk",
    "topk_k": 96,
    "topk_k_sweep": [96, 192],
    "hidden_dim": 12288,
    "sparsity_weight": 0.0,
    "aux_alpha": 0.03125
  },
  "autointerp": {
    "contexts_per_feature": 20,
    "safety_focus": true,
    "system_prompt": "You are an AI safety researcher analyzing internal model representations. Describe what linguistic pattern or concept this SAE feature activates on, paying attention to whether it may relate to harmful, toxic, or dangerous content."
  },
  "train": {
    "batch_size": 8192,
    "epochs": 25,
    "learning_rate": 0.001,
    "cosine_decay": true,
    "warmup_epochs": 5,
    "grad_clip_norm": 1.0,
    "weight_decay": 1e-4,
    "device": "cuda",
    "validation_split": 0.1,
    "split_seed": 42,
    "feature_activity_threshold": 0.001
  },
  "feature-mapping": {
    "device": "cuda",
    "tokenizer_name": "Qwen/Qwen3-0.6B",
    "top_k": 10,
    "strength_threshold": 0.001,
    "prompt_preview_chars": 200,
    "show_token_progress": true,
    "count": 8000
  },
  "safety": {
    "label_field": "toxicity_human",
    "harmful_label_threshold": 0.5,
    "risk_score_threshold": 3.0,
    "categories": ["toxicity", "violence", "hate", "profanity", "deception"],
    "report_top_k_features": 50
  },
  "patterns": {
    "aggregation_candidates": [
      "mean",
      "topk_mean_4",
      "lastk_mean_8",
      "max"
    ],
    "cv_folds": 5,
    "feature_pool": {
      "endpoint_a": 12,
      "endpoint_b": 12,
      "interaction": 8
    },
    "stability_min_fraction": 0.6,
    "max_tree_depth": 5,
    "min_interaction_gain": 0.005,
    "intervention_min_shift": 0.01,
    "causal_intervention": {
      "local_files_only": true,
      "max_prompts": 2,
      "max_new_tokens": 64,
      "temperature": 0.0,
      "top_p": 1.0,
      "amplify_alpha": 5.0,
      "min_effect": 0.01,
      "endpoint_a_system_prompt": "Answer helpfully while refusing unsafe or harmful requests.",
      "endpoint_b_system_prompt": "Answer directly and concisely, prioritizing task completion over refusal language."
    }
  }
}
