{
  "model_name": "ytu-ce-cosmos/turkish-gpt2",
  "dataloader": {
    "dataset_name": "AnasAlokla/multilingual_go_emotions",
    "dataset_config_name": null,
    "split": "train",
    "data_dir": null,
    "streaming": false,
    "text_field": "text",
    "filter_field": "language",
    "filter_values": [
      "tr",
      "turkish",
      "Turkish"
    ]
  },
  "extraction": {
    "extractor_backend": "hf",
    "target": [
      "blocks.0.hook_resid_post",
      "blocks.6.hook_resid_post",
      "blocks.11.hook_resid_post"
    ],
    "count": 5000,
    "chunk_size": 1000000,
    "dtype": "bfloat16"
  },
  "sae": {
    "hidden_dim": 12288,
    "sparsity_weight": 0.005,
    "sparsity_sweep": [
      0.0005,
      0.002,
      0.005,
      0.01,
      0.02
    ]
  },
  "train": {
    "batch_size": 256,
    "epochs": 5,
    "learning_rate": 0.0005,
    "weight_decay": 0.0,
    "device": "cuda",
    "validation_split": 0.1,
    "split_seed": 42,
    "feature_activity_threshold": 0.001
  },
  "feature-mapping": {
    "device": "cuda",
    "tokenizer_name": "ytu-ce-cosmos/turkish-gpt2",
    "top_k": 10,
    "strength_threshold": 0.001,
    "prompt_preview_chars": 180,
    "show_token_progress": true,
    "count": 3000
  }
}