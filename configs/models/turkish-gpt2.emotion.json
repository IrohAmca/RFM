{
  "model_name": "ytu-ce-cosmos/turkish-gpt2",
  "dataloader": {
    "dataset_name": "AnasAlokla/multilingual_go_emotions",
    "dataset_config_name": null,
    "split": "train",
    "data_dir": null,
    "streaming": false,
    "text_field": "text",
    "filter_field": "language",
    "filter_values": [
      "tr",
      "turkish",
      "Turkish"
    ]
  },
  "extraction": {
    "extractor_backend": "hf",
    "count": 5000,
    "chunk_size": 1000000,
    "dtype": "bfloat16"
  },
  "layers": {
    "blocks.0.hook_resid_post": {},
    "blocks.6.hook_resid_post": {},
    "blocks.11.hook_resid_post": {}
  },
  "sae": {
    "architecture": "topk",
    "topk_k": 64,
    "topk_k_sweep": [64, 128],
    "hidden_dim": 12288,
    "sparsity_weight": 0.0
  },
  "autointerp": {
    "contexts_per_feature": 15
  },
  "train": {
    "batch_size": 256,
    "epochs": 25,
    "learning_rate": 0.001,
    "lr_decay_factor": 0.5,
    "lr_decay_patience": 5,
    "weight_decay": 1e-4,
    "device": "cuda",
    "validation_split": 0.1,
    "split_seed": 42,
    "feature_activity_threshold": 0.001
  },
  "feature-mapping": {
    "device": "cuda",
    "tokenizer_name": "ytu-ce-cosmos/turkish-gpt2",
    "top_k": 10,
    "strength_threshold": 0.001,
    "prompt_preview_chars": 180,
    "show_token_progress": true,
    "count": 5000
  },
  "patterns": {
    "aggregation_candidates": [
      "mean",
      "topk_mean_4",
      "lastk_mean_8",
      "max"
    ],
    "cv_folds": 5,
    "feature_pool": {
      "endpoint_a": 12,
      "endpoint_b": 12,
      "interaction": 8
    },
    "stability_min_fraction": 0.6,
    "max_tree_depth": 5,
    "min_interaction_gain": 0.005,
    "intervention_min_shift": 0.01,
    "causal_intervention": {
      "local_files_only": true,
      "max_prompts": 2,
      "max_new_tokens": 48,
      "temperature": 0.0,
      "top_p": 1.0,
      "amplify_alpha": 5.0,
      "min_effect": 0.01
    }
  }
}
